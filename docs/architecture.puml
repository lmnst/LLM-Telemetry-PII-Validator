@startuml architecture
title Parallel Range-GET Download Lifecycle

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundCorner 6
skinparam sequence {
    ArrowColor          #2C3E50
    ActorBorderColor    #2C3E50
    LifeLineBorderColor #95A5A6
    LifeLineBackgroundColor #ECF0F1
    ParticipantBorderColor #2C3E50
    ParticipantBackgroundColor #FAFAFA
    ParticipantFontStyle bold
    NoteBorderColor #B8862E
    NoteBackgroundColor #FFF7E1
    DividerBackgroundColor #ECF0F1
    DividerFontStyle bold
}

actor "Caller" as App
participant "Downloader" as DL
participant "FileAssembler" as FS
participant "HTTP Server" as Srv

== Preflight ==
App -> DL : download(uri, dest)
DL -> Srv : HEAD
Srv --> DL : 200 (Accept-Ranges, ETag, Content-Length=N)
DL -> FS : open <dest>.part

== Probe chunk 0 (synchronous) ==
note right of DL
  Probe runs synchronously so a
  200-on-ranged-GET cannot trigger
  N parallel writers to overlap.
end note
DL -> Srv : GET Range: bytes=0-(C-1)
Srv --> DL : 206 Partial Content
DL -> FS : write @offset 0

== Chunks 1..k (Semaphore-bounded by parallelism) ==
par
    DL -> Srv : GET bytes=C-(2C-1)
    Srv --> DL : 206
    DL -> FS : write @offset C
also
    DL -> Srv : GET bytes=2C-(3C-1)
    Srv --> DL : 206
    DL -> FS : write @offset 2C
also
    DL -> Srv : GET bytes=...
    Srv --> DL : 206
    DL -> FS : write @offset ...
end

== Commit ==
note right of DL
  SHA-256 streams the temp file
  BEFORE the atomic move, so a
  corrupt file is never visible
  at the destination path.
end note
DL -> FS : stream digest
DL -> FS : fsync + ATOMIC_MOVE -> dest
FS --> DL : committed
DL --> App : Success(bytes, elapsed, sha256?)

@enduml
